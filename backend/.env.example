# ── Database ──────────────────────────────────────────────────────────────────
# Neon: postgresql+psycopg2://user:password@host/dbname?sslmode=require
# Local: postgresql+psycopg2://postgres:password@localhost:5432/aayu_printing
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
